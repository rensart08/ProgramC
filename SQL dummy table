SELECT
    *,

    CASE
        WHEN pais_cliente = 'Brasil' THEN 1
        ELSE 0
    END AS pais_brasil,

    CASE
        WHEN pais_cliente = 'Canadá' THEN 1
        ELSE 0
    END AS pais_canada,

    CASE
        WHEN pais_cliente = 'Inglaterra' THEN 1
        ELSE 0
    END AS pais_inglaterra

FROM cap06.vendas_loja_online;
